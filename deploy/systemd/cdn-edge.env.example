# /etc/default/cdn-edge — systemd EnvironmentFile for cdn-edge.service
# Copy to /etc/default/cdn-edge and edit to suit your deployment.

# --- Required ---
CDN_ORIGIN=https://origin.example.com

# --- Network ---
CDN_LISTEN=:443
CDN_ADMIN_LISTEN=127.0.0.1:9090

# --- TLS ---
CDN_TLS=true
CDN_TLS_CERT=/etc/ssl/certs/edge.crt
CDN_TLS_KEY=/etc/ssl/private/edge.key
CDN_HTTPS_REDIRECT=true

# --- Cache ---
CDN_MAX_CACHE_ITEMS=100000
CDN_MAX_CACHE_ENTRY_BYTES=10485760
CDN_DISK_CACHE_DIR=/var/cache/cdn-edge
CDN_DISK_CACHE_MAX_MB=8192
CDN_DEFAULT_TTL=5m

# --- Origin ---
CDN_ORIGIN_TIMEOUT=30s
CDN_COALESCE_TIMEOUT=30s
# CDN_ORIGIN_HOST=origin.internal.example.com

# --- Security ---
CDN_ADMIN_API_KEY=change-me-to-a-long-random-string
CDN_RATE_LIMIT_RPS=1000
CDN_RATE_LIMIT_BURST=2000

# --- CORS (optional) ---
# CDN_CORS_ORIGINS=https://app.example.com,https://www.example.com

# --- Compression / Logging ---
CDN_COMPRESS=true
CDN_LOG_LEVEL=info
